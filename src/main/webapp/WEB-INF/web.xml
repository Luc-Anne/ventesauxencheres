<!DOCTYPE web-app PUBLIC
 "-//Sun Microsystems, Inc.//DTD Web Application 2.3//EN"
 "http://java.sun.com/dtd/web-app_2_3.dtd" >

<web-app>
  <display-name>ventesauxencheres</display-name>
  <description>Projet de groupe à l'ENI visant à développer un site de ventes aux enchères.</description>

  <context-param>
    <param-name>debutTitre</param-name>
    <param-value>Ventes aux Enchères -</param-value>
  </context-param>

  <session-config>
    <session-timeout>5</session-timeout>
  </session-config>

  <welcome-file-list>
    <welcome-file>home</welcome-file>
  </welcome-file-list>

  <error-page>
    <error-code>403</error-code>
    <location>/error/403.jsp</location>
  </error-page>
  <error-page>
    <error-code>404</error-code>
    <location>/error/404.jsp</location>
  </error-page>
  <error-page>
    <error-code>500</error-code>
    <location>/error/500.jsp</location>
  </error-page>

</web-app>
